{
  "name": "file-transfer",
  "version": "1.0.0",
  "main": "main.js",
  "scripts": {
    "electron": "electron . --disable-gpu",
    "dist": "electron-builder --win --x64"
  },
  "build": {
    "appId": "com.filetransfer.app",
    "productName": "FileTransfer",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "wraperfunction.node",
      "config.json",
      "build/**/*",
      "node_modules/**/*"
    ],
    "extraResources": [
      {
        "from": "wraperfunction.node",
        "to": "wraperfunction.node"
      }
    ],
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "devDependencies": {
    "electron": "^29.4.6",
    "electron-builder": "^24.0.0"
  }
}