{
  "name": "file-transfer",
  "version": "1.0.0",
  "description": "File Transfer Application",
  "author": "chidumshetti <chidumshetti30@gmail.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/chidumshetti/file_transfer.git"
  },
  "main": "main.js",
  "scripts": {
    "electron": "electron . --disable-gpu",
    "dist": "electron-builder --win --x64",
    "dist:linux": "electron-builder --linux --x64"
  },
  "build": {
    "appId": "com.filetransfer.app",
    "productName": "FileTransfer",
    "compression": "maximum",
    "asar": true,
    "asarUnpack": [
      "wraperfunction.node"
    ],
    "publish": {
      "provider": "github",
      "owner": "chidumshetti",
      "repo": "file_transfer"
    },
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "wraperfunction.node",
      "config.json",
      "build/**/*",
      "node_modules/**/*"
    ],
    "extraResources": [
      {
        "from": "wraperfunction.node",
        "to": "wraperfunction.node"
      }
    ],
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "linux": {
      "target": [
        { "target": "AppImage", "arch": ["x64"] },
        { "target": "deb",      "arch": ["x64"] }
      ],
      "category": "Utility"
    }
  },
  "devDependencies": {
    "electron": "^29.4.6",
    "electron-builder": "^24.0.0"
  }
}